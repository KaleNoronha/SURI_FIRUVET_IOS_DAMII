                                <rect key="frame" x="23" y="207" width="346" height="60"/>
                                <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
                                <string key="text">Las empresas deben pasar un proceso de validacion de identidad y permisos legales para operar. Al registrarse aceptan la auditoria de sus servicios por parte de Firuvet.</string>
                                <fontDescription key="fontDescription" type="system" pointSize="13"/>
