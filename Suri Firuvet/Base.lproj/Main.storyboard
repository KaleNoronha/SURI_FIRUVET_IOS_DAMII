                                <rect key="frame" x="23" y="299" width="346" height="74"/>
                                <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
                                <string key="text">El usuario tendra acceso a actualizaciones en tiempo real sobre los procedimientos realizados. La epresa se compromete a mantener la informacion actualizada y veraz.</string>
                                <fontDescription key="fontDescription" type="system" pointSize="13"/>
                                <color key="textColor" systemColor="secondarySystemGroupedBackgroundColor"/>
                                <nil key="highlightedColor"/>
